# CakePHP specific files #
##########################
/config/app_local.php
/config/.env
/logs/*
/tmp/*
/vendor/*

# --- CakePHP Logs y Temporales ---
# Ignorar el contenido de logs, pero mantener la carpeta
/logs/*
!/logs/.gitkeep
!/logs/empty

# Ignorar caché, sesiones y archivos temporales
/tmp/*
!/tmp/.gitkeep
!/tmp/empty

# --- Dependencias ---
# Nunca subir la carpeta vendor (se instala con composer install)
/vendor/

# --- Base de Datos (SQLite) ---
# Si usas SQLite localmente, no la subas
/db/*.sqlite

# --- Sistema Operativo e IDEs ---
# Archivos basura de Mac y Windows
.DS_Store
Thumbs.db

# --- Archivos de Configuración ---
# Ignorar archivos de configuración locales
php.ini
.htaccess
phpinfo.php
robots.txt

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
# Icon must end with two \r
Icon

ehthumbs.db
Thumbs.db
.directory

# Tool specific files #
#######################
# PHPUnit
.phpunit.cache
tests.sqlite
# vim
*~
*.swp
*.swo
# sublime text & textmate
*.sublime-*
*.stTheme.cache
*.tmlanguage.cache
*.tmPreferences.cache
# Eclipse
.settings/*
# JetBrains, aka PHPStorm, IntelliJ IDEA
.idea/*
# NetBeans
nbproject/*
# Visual Studio Code
.vscode
# nova
.nova
# Sass preprocessor
.sass-cache/
# node
/node_modules/*
# yarn
yarn-debug.log
yarn-error.log
